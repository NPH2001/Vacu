{
  "name": "farm-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "check:layout": "node scripts/check-layout.mjs",
    "test:watch": "vitest",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:generate": "DOTENV_CONFIG_PATH=.env.local drizzle-kit generate",
    "db:migrate": "DOTENV_CONFIG_PATH=.env.local tsx db/migrate.ts",
    "db:seed": "node --env-file=.env.local scripts/seed.mjs",
    "db:seed-admin": "DOTENV_CONFIG_PATH=.env.local tsx db/seed-admin.ts"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@tiptap/extension-image": "^3.28.0",
    "@tiptap/extension-placeholder": "^3.28.0",
    "@tiptap/extension-text-align": "^3.28.0",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/react": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "@types/nodemailer": "^8.0.0",
    "drizzle-orm": "^0.45.2",
    "entities": "^8.0.0",
    "jose": "^6.2.2",
    "next": "16.2.3",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanitize-html": "^2.17.6",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "playwright": "^1.61.1",
    "tailwindcss": "^4",
    "testcontainers": "^11.14.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
