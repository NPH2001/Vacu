# ─── Required ────────────────────────────────────────────────────────
# Public domain Traefik will route to this app.
APP_DOMAIN=vacu.example.com

# 32+ bytes of random — sign session JWTs. Generate: openssl rand -base64 32
AUTH_SECRET=replace-me-with-32-plus-random-bytes

# Postgres credentials (postgres container reads these on first boot)
POSTGRES_USER=vacu
POSTGRES_PASSWORD=replace-me-strong-password
POSTGRES_DB=vacu

# Initial admin user — created on first start. Remove these AFTER first boot
# (the user will already exist; the seed script becomes a no-op).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-me-strong-password

# ─── Traefik wiring (defaults usually fine) ──────────────────────────
# External Docker network shared with your Traefik container.
TRAEFIK_NETWORK=traefik
# HTTPS entrypoint name configured in your Traefik static config.
TRAEFIK_ENTRYPOINT=websecure
# HTTP entrypoint (used only by the http→https redirect router).
TRAEFIK_HTTP_ENTRYPOINT=web
# Cert resolver name configured in your Traefik static config.
TRAEFIK_CERT_RESOLVER=letsencrypt

# ─── Image tagging (optional) ────────────────────────────────────────
# IMAGE_NAME=registry.example.com/vacu/app
# IMAGE_TAG=v1.0.0
